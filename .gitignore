go.work
go.work.sum
.env
.env.local

# ── IDE / OS ───────────────────────────────────────────────────────────────
.DS_Store
.idea/
*.swp
*.swo
.vscode/settings.json

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/
